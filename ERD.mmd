    PROMOTION {
        int id PK
        string name
        string promotion_type
        decimal discount_value
        datetime starts_at
        datetime ends_at
        int max_quantity
        int sold_quantity
        bool is_active
    }

    PROMOTION_PRODUCT {
        int promotion_id FK
        int product_variant_id FK
    }

    COUPON {
        int id PK
        string code UK
        string discount_type
        decimal discount_value
        datetime expires_at
        bool is_active
    }


    %% =========================
    %% SEARCH & RECOMMENDATION
    %% =========================

    PRODUCT_VIEW {
        int id PK
        int user_id FK
        int product_id FK
        datetime viewed_at
    }

    USER_INTERACTION {
        int id PK
        int user_id FK
        int product_id FK
        string interaction_type
        int weight
        datetime created_at
    }


    %% =========================
    %% AI CHAT
    %% =========================

    CHAT_SESSION ||--o{ CHAT_MESSAGE : contains

    CHAT_SESSION {
        int id PK
        int user_id FK
        datetime created_at
    }

    CHAT_MESSAGE {
        int id PK
        int chat_session_id FK
        string role
        text content
        datetime created_at
    }

